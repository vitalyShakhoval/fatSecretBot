# Garmin Connect credentials
# Copy this file to .env and fill in your credentials

EMAIL=your_email@example.com
PASSWORD=your_password
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# FatSecret API credentials (for fatsecret_app.py)
# Option A (recommended): OAuth 1.0a credentials
# Consumer key/secret from FatSecret app settings (OAuth v1)
FATSECRET_CONSUMER_KEY=
FATSECRET_CONSUMER_SECRET=
# Optional user token pair for user-authorized requests
FATSECRET_OAUTH_TOKEN=
FATSECRET_OAUTH_TOKEN_SECRET=

# Option B (fallback): OAuth2 bearer token
FATSECRET_ACCESS_TOKEN=

# OAuth2 app credentials (used only to obtain FATSECRET_ACCESS_TOKEN externally)
FATSECRET_CLIENT_ID=
FATSECRET_CLIENT_SECRET=

# Optional: endpoint-specific id for food_entries.get.v2
FATSECRET_FOOD_ENTRY_ID=

# Optional date for logs in fatsecret_app.py (YYYY-MM-DD)
# FATSECRET_LOG_DATE=2026-04-12
# Optional: API token storage path (default: ~/.garminconnect)
# TOKEN_PATH=~/.garminconnect